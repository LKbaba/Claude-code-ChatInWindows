# 开发相关文件
.vscode/**
.vscode-test/**
src/**
.gitignore
.yarnrc
vsc-extension-quickstart.md
**/tsconfig.json
**/eslint.config.mjs
**/*.map
**/*.ts
**/.vscode-test.*

# 依赖优化 - 排除不必要的 node_modules
node_modules/**
!node_modules/glob/**
# node-pty native module: platform-specific VSIX (win32-x64) must ship the
# prebuilt .node binaries. node-pty 1.1.0 is N-API based, so the prebuild is
# ABI-stable across Electron versions (no @electron/rebuild needed).
# Re-include only the win32-x64 runtime files; .pdb debug symbols (~40MB) and
# other-OS prebuilds are intentionally left excluded by the broad node_modules/** rule.
!node_modules/node-pty/lib/**
!node_modules/node-pty/package.json
!node_modules/node-pty/prebuilds/win32-x64/*.node
!node_modules/node-pty/prebuilds/win32-x64/winpty.dll
!node_modules/node-pty/prebuilds/win32-x64/winpty-agent.exe
!node_modules/node-pty/prebuilds/win32-x64/conpty/**

# 文档和测试文件
**/*.test.js
**/*.test.ts
**/test/**
**/*.spec.js
**/*.spec.ts
docs/**
*.md
!README.md
!README.zh-CN.md
!README.zh-TW.md
!CLAUDE.md

# 构建和配置文件
webpack.config.js
.eslintrc*
.prettierrc*
.editorconfig
*.log
*.lock
package-lock.json
yarn.lock
pnpm-lock.yaml

# Git相关
.git/**
.github/**
!.github/workflows/

# 打包产物
*.vsix
*.zip

# 临时文件
*.tmp
*.temp
.DS_Store
Thumbs.db

# 调试日志文件
debug_log.txt
debug_log.bak
log.txt

# Claude 本地配置
.claude/**

# 截图和PDF文件夹（如果很大的话）
CCimages/**

# Reference files (development only)
reference/**

# Spec/planning documents (development only)
specs/**

# Test hook scripts (development only)
test-hooks/**

# Dev-only probe & smoke-test scripts
scripts/**

# Dev-only agent / codex config (not needed at runtime)
.agents/**
.codex/**
